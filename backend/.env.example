APP_NAME=CloudSync Backup
API_KEY=unhackable-demo-key-change-me
DATABASE_URL=postgresql+asyncpg://cloudsync:cloudsync_secret@db:5432/cloudsync_db
UPLOAD_DIR=storage
MAX_UPLOAD_SIZE_MB=500
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost,http://localhost:3000
CHUNK_READ_SIZE=1048576
RATE_LIMIT=100/minute
BUILD_VERSION=1.0.0
